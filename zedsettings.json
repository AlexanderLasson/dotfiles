{
  "git_panel": {
    "tree_view": true
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false
  },
  "disable_ai": false,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "ensure_final_newline_on_save": false,
  "format_on_save": "off",
  "show_edit_predictions": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Gruvbox Dark Hard",
}

